<div class="navbar navbar-expand-sm navbar-light navbar-lewagon px-3 border-bottom mb-5">
  <div class="container-fluid">
    <%= link_to articles_path, class: "navbar-brand" do %>
      <i class="fa-solid fa-book-open-reader"></i> Wikinimous
    <% end %>
  </div>
</div>

<div class="container">
  <div class="row justify-content-center">
    <div class="col-12 col-md-6">
      <h1 class="mb-4">New Article</h1>

      <%= form_with model: @article do |f| %>
        <div class="mb-3">
          <%= f.label :title, class: "form-label" %>
          <%= f.text_field :title, class: "form-control", placeholder: "The title of your article" %>
        </div>

        <div class="mb-3">
          <%= f.label :content, class: "form-label" %>
          <%= f.text_area :content, class: "form-control", rows: 10, placeholder: "Content of your article" %>
        </div>

        <div class="d-grid gap-2 mb-3">
          <%= f.submit "Create Article", class: "btn btn-primary" %>
        </div>
      <% end %>

      <hr>
      <%= link_to "Back to list", articles_path, class: "text-secondary decoration-none" %>
    </div>
  </div>
</div>


