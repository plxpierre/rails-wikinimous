<div class="navbar navbar-expand-sm navbar-light navbar-lewagon px-3 border-bottom mb-5">
  <div class="container-fluid">
    <%= link_to articles_path, class: "navbar-brand" do %>
      <i class="fa-solid fa-book-open-reader"></i> Wikinimous
    <% end %>
  </div>
</div>

<div class="container">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8">
      <div class="d-flex align-items-center mb-3">
        <h1 class="me-3"><%= @article.title %></h1>
        <%= link_to edit_article_path(@article), class: "text-secondary" do %>
          <i class="fa-solid fa-pen-to-square"></i>
        <% end %>
      </div>

      <div class="article-content mb-5">
        <p style="white-space: pre-wrap;"><%= @article.content %></p>
      </div>

      <hr>

      <div class="d-flex justify-content-between align-items-center">
        <%= link_to "Back to list", articles_path, class: "btn btn-light" %>

        <%= link_to article_path(@article),
            data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
            class: "text-danger text-decoration-none" do %>
          <i class="fa-solid fa-trash-can"></i> Delete
        <% end %>
      </div>
    </div>
  </div>
</div>









